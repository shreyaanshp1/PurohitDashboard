SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Browser API target. Leave blank for local Vite proxy at /api.
VITE_AUTH_ENDPOINT=
VITE_PURCHASE_LOG_ENDPOINT=

# Password reset links. The UI sends its current URL by default; set this for deployed APIs.
APP_BASE_URL=
PASSWORD_RESET_APP_URL=
PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# Option A: Resend
RESEND_API_KEY=
AUTH_EMAIL_FROM="Santosh Portfolio <no-reply@example.com>"

# Option B: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Santosh Portfolio <no-reply@example.com>"

# Local development only: logs reset email content instead of sending.
PASSWORD_RESET_EMAIL_MODE=
