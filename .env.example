# Required for the private Node API, receipts, purchases, auth users, and Gmail imports.
# Use the Supabase project URL, not a /rest/v1 URL.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Optional alias. Use this instead of SUPABASE_SERVICE_ROLE_KEY if you prefer the newer name.
SUPABASE_SECRET_KEY=

# Local development only: lets the browser sign in without Supabase auth records.
VITE_DEMO_USERNAME=
VITE_DEMO_PASSWORD=
VITE_DEMO_NAME=
VITE_DEMO_ROLE=

# Optional browser API targets. Leave blank for local Vite proxy at /api.
VITE_AUTH_ENDPOINT=
VITE_PURCHASE_LOG_ENDPOINT=

# Optional direct browser Supabase auth fallback. Do not use service-role keys here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Local API server settings.
PURCHASE_LOG_SERVER_PORT=8787
PURCHASE_LOG_ALLOWED_ORIGIN=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174
PURCHASE_STORAGE_DRIVER=supabase
AUTH_SIGNUP_DEFAULT_ROLE=user

# Gmail OAuth for Costco and US Mint imports.
GOOGLE_OAUTH_DISABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8787/api/google/oauth/callback
GOOGLE_OAUTH_TOKEN_FILE=secrets/google-oauth-token.json
COSTCO_GMAIL_QUERY=
COSTCO_GMAIL_IMPORT_LIMIT=500
US_MINT_GMAIL_QUERY=
US_MINT_GMAIL_IMPORT_LIMIT=500

# Google Sheets service account. Use one of these credential options:
# 1. GOOGLE_SERVICE_ACCOUNT_KEY_FILE=secrets/google-sheet-api.json
# 2. GOOGLE_SERVICE_ACCOUNT_JSON='{"client_email":"...","private_key":"..."}'
# 3. GOOGLE_SERVICE_ACCOUNT_EMAIL plus GOOGLE_PRIVATE_KEY.
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Purchase sheet settings.
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=Purchases

# Travel workbook settings.
TRAVEL_SPREADSHEET_ID=
TRAVEL_SHEET_NAMES=Trips,Flights,Certificates_Awards
TRAVEL_MASTER_DATA_SPREADSHEET_ID=
TRAVEL_MASTER_DATA_HEADER_ROW=1
TRAVEL_MASTER_DATA_SHEET_NAMES=
VITE_TRAVEL_SHEETS_ENDPOINT=
VITE_TRAVEL_MASTER_DATA_ENDPOINT=

# Dashboard section spreadsheets. Values may be raw spreadsheet IDs or full Google Sheets URLs.
COSTCO_SPREADSHEET_ID=
COSTCO_SHEET_NAMES=Accounts,Transactions,Orders,Rewards,Renewals
US_MINT_SPREADSHEET_ID=
US_MINT_SHEET_NAMES=Accounts,Orders,Release Calendar,Subscriptions,Expected Charges,Buyer Sales
DELL_SPREADSHEET_ID=
DELL_SHEET_NAMES=Accounts,Orders,Items,Rewards,Fulfillment,Sales
COMMODITIES_SPREADSHEET_ID=
COMMODITIES_SHEET_NAMES=Inventory,Sales
BUYERS_SPREADSHEET_ID=
BUYERS_SHEET_NAMES=Buyers
REWARDS_SPREADSHEET_ID=
REWARDS_SHEET_NAMES=Rewards
ALERTS_SPREADSHEET_ID=
ALERTS_SHEET_NAMES=Alerts
REPORTS_SPREADSHEET_ID=
REPORTS_SHEET_NAMES=Reports

# Legacy browser Google Sheets writer, only if using the old Apps Script path.
VITE_GOOGLE_SHEETS_WEB_APP_URL=
VITE_GOOGLE_SHEET_ID=
VITE_GOOGLE_SHEET_NAME=Purchases
VITE_GOOGLE_SHEETS_SHARED_SECRET=

# Receipt file uploads.
RECEIPT_FILE_UPLOAD_DIR=uploads/receipts
RECEIPT_FILE_MAX_BYTES=10485760

# Password reset links. The UI sends its current URL by default; set this for deployed APIs.
APP_BASE_URL=
PASSWORD_RESET_APP_URL=
PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# Password reset email option A: Resend.
RESEND_API_KEY=
AUTH_EMAIL_FROM="Santosh Portfolio <no-reply@example.com>"

# Password reset email option B: SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_HELO_NAME=localhost
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Santosh Portfolio <no-reply@example.com>"

# Local development only: logs reset email content instead of sending.
PASSWORD_RESET_EMAIL_MODE=console

# Archived Airtable integration. Leave blank unless intentionally reviving it.
AIRTABLE_BASE_ID=
AIRTABLE_PERSONAL_ACCESS_TOKEN=
AIRTABLE_TOKEN=
AIRTABLE_API_KEY=
